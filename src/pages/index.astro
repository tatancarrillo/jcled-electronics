<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>JCLED Electronics</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f1115;
      color: white;
      text-align: center;
    }

    .hero {
      padding: 80px 20px;
    }

    h1 {
      font-size: 3rem;
      margin-bottom: 10px;
      color: #00d4ff;
    }

    h2 {
      font-weight: normal;
      margin-bottom: 40px;
    }

    .servicios {
      max-width: 900px;
      margin: auto;
      padding: 20px;
    }

    .card {
      background: #1a1f27;
      margin: 15px;
      padding: 20px;
      border-radius: 12px;
    }

    .contacto {
      margin-top: 40px;
