</head>

<body>

  <section class="hero">
   <img src="/logo electronis.png" alt="JCLED Electronics" style="max-width: 700px; width: 90%;" /> 
    <h2>Audio • Iluminación • Tecnología</h2>
  </section>

  <section class="servicios">

    <div class="card">
      <h3>Pantallas LED</h3>
      <p>Instalación, mantenimiento y reparación.</p>
    </div>

    <div class="card">
      <h3>Audio Profesional</h3>
      <p>Diagnóstico, reparación y soluciones de sonido.</p>
    </div>

    <div class="card">
      <h3>Iluminación LED</h3>
      <p>Diseño y fabricación de proyectos LED personalizados.</p>
    </div>

    <div class="card">
      <h3>Impresión 3D</h3>
